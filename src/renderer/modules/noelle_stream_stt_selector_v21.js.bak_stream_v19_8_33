"use strict";
/* Noelle Stream STT Selector V21 — robust existing-only replacement */
(() => {
  const VERSION = "21.1-stream-stt-selector-robust-2026";
  const STORAGE_KEY = "noelle.stream.stt.config.v21";

  const DEFAULT_CONFIG = { engine: "auto", model: "small", language: "pt" };

  function qs(selector, root = document) {
    return root.querySelector(selector);
  }

  function loadConfig() {
    try {
      return { ...DEFAULT_CONFIG, ...JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}") };
    } catch {
      return { ...DEFAULT_CONFIG };
    }
  }

  function saveConfig(config) {
    const next = { ...DEFAULT_CONFIG, ...config };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(next)); } catch {}
    window.dispatchEvent(new CustomEvent("noelle-stream-stt-config-change-v21", { detail: { version: VERSION, config: next } }));
    return next;
  }

  function streamRoot() {
    return qs("#streamFinalizePanelV19833") ||
      qs("#streamSegmentPanelV19832") ||
      qs("#streamVadPanelV19831") ||
      qs('.page[data-page="stream"] .stream-v19829-shell') ||
      qs('.page[data-page="stream"]') ||
      null;
  }

  function ensureSelector() {
    if (qs("#streamSTTSelectorV21")) return;
    const root = streamRoot();
    if (!root) return;

    const config = loadConfig();
    const box = document.createElement("section");
    box.id = "streamSTTSelectorV21";
    box.className = "stream-v19829-card";
    box.setAttribute("data-noelle-stt-selector-v21", "true");
    box.innerHTML = `
      <h3>STT</h3>
      <label>Engine
        <select id="streamSTTEngineV21">
          <option value="auto">auto</option>
          <option value="faster-whisper">faster-whisper</option>
          <option value="whisper.cpp">whisper.cpp</option>
          <option value="openai-whisper">openai-whisper</option>
        </select>
      </label>
      <label style="margin-left:8px;">Modelo
        <select id="streamSTTModelV21">
          <option value="tiny">tiny</option>
          <option value="base">base</option>
          <option value="small">small</option>
          <option value="medium">medium</option>
          <option value="large-v3">large-v3</option>
        </select>
      </label>
      <label style="margin-left:8px;">Idioma
        <select id="streamSTTLanguageV21">
          <option value="pt">pt</option>
          <option value="auto">auto</option>
          <option value="en">en</option>
          <option value="ja">ja</option>
        </select>
      </label>
      <p class="muted" id="streamSTTConfigNoteV21">Configuração local salva no navegador. O backend real entra pelo preload/main.</p>
    `;

    root.insertAdjacentElement("afterend", box);

    const engine = qs("#streamSTTEngineV21");
    const model = qs("#streamSTTModelV21");
    const language = qs("#streamSTTLanguageV21");

    if (engine) engine.value = config.engine;
    if (model) model.value = config.model;
    if (language) language.value = config.language;

    const onChange = () => {
      const next = saveConfig({
        engine: engine?.value || "auto",
        model: model?.value || "small",
        language: language?.value || "pt"
      });
      window.streamSTTStatus?.(`STT configurado: ${next.engine}/${next.model}/${next.language}`);
    };

    engine?.addEventListener("change", onChange);
    model?.addEventListener("change", onChange);
    language?.addEventListener("change", onChange);
  }

  function bind() {
    if (window.__NOELLE_STREAM_STT_SELECTOR_V21_BOUND__) return;
    window.__NOELLE_STREAM_STT_SELECTOR_V21_BOUND__ = true;
    ensureSelector();
    document.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof HTMLElement && target.closest('[data-target="stream"]')) {
        setTimeout(ensureSelector, 180);
      }
    }, true);
  }

  window.NoelleStreamSttSelectorV21 = Object.freeze({
    version: VERSION,
    bind,
    ensureSelector,
    getConfig: loadConfig,
    setConfig: saveConfig
  });

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", bind, { once: true });
  else bind();
})();