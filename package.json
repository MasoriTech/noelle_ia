{
  "name": "noelle-companion-v16-restore",
  "version": "19.6.0-avatar-lab-isolated-2026",
  "description": "Noelle Companion 2026 - boot coeso, Chat IA, avatar/widget, emotes VRMA, expressões PNG, inventário GLB e TTS/STT preparados.",
  "main": "main.js",
  "author": "MasoriTech / Noelle Companion",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "diagnostico": "node scripts/diagnostico_v17_4_1_main.cjs",
    "doctor": "node scripts/diagnostico_v17_4_tray.cjs",
    "check": "node --check main.js && node --check preload.js && node --check src/renderer/controls_window_app.js && node --check src/renderer/avatar_window_app.js",
    "dist:win": "electron-builder --win nsis portable",
    "build-room": "node scripts/build_room_v19_2026.cjs",
    "diagnostico-room": "node scripts/diagnostico_room_v19_2026.cjs",
    "diagnostico:v19": "node scripts/diagnostico_room_v19_2026.cjs",
    "diagnostico:v19.2": "node scripts/diagnostico_v19_2_settings_about_cleanup_2026.cjs",
    "apply:v19.2": "node scripts/apply_v19_2_settings_about_cleanup_2026.cjs --apply",
    "apply:v19.2.1": "node scripts/apply_v19_2_1_settings_about_room_fix_2026.cjs --apply",
    "diagnostico:v19.2.1": "node scripts/diagnostico_v19_2_1_settings_about_room_fix_2026.cjs",
    "apply:v19.3": "node scripts/apply_v19_3_complete_ui_md_2026.cjs --apply",
    "diagnostico:v19.3": "node scripts/diagnostico_v19_3_complete_ui_md_2026.cjs",
    "build:avatar-v19.5": "node scripts/build_avatar_v19_5_2026.cjs",
    "apply:v19.5-avatar": "node scripts/apply_v19_5_avatar_real_vrm_sync_anim_2026.cjs --apply",
    "diagnostico:v19.5-avatar": "node scripts/diagnostico_v19_5_avatar_real_vrm_sync_anim_2026.cjs",
    "build:avatar-lab-v19.6": "node scripts/build_avatar_lab_v19_6_2026.cjs",
    "apply:v19.6-avatar-lab": "node scripts/apply_v19_6_avatar_lab_isolated_2026.cjs --apply",
    "diagnostico:v19.6-avatar-lab": "node scripts/diagnostico_v19_6_avatar_lab_isolated_2026.cjs"
  },
  "dependencies": {
    "@pixiv/three-vrm": "3.5.2",
    "three": "0.184.0",
    "@pixiv/three-vrm-animation": "3.5.2"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "esbuild": "0.28.0"
  },
  "build": {
    "appId": "com.masoritech.noelle",
    "productName": "Noelle Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "tools/**/*",
      "scripts/**/*",
      "requirements.txt"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/app.ico"
    }
  }
}
