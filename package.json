{
  "name": "noelle-companion-v16-restore",
  "version": "17.0.0-maintenance",
  "description": "Noelle Companion 2026 - boot coeso, Chat IA, avatar/widget, emotes VRMA, expressões PNG, inventário GLB e TTS/STT preparados.",
  "main": "main.js",
  "author": "MasoriTech / Noelle Companion",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "diagnostico": "node scripts/diagnostico_v17.cjs",
    "doctor": "node scripts/diagnostico_v17.cjs",
    "bootstrap": "node scripts/noelle_maintenance_v17.cjs --apply",
    "rebuild:manifests": "node scripts/rebuild_manifests_noelle.cjs",
    "dist:win": "electron-builder --win nsis portable",
    "build-renderers": "node scripts/bundle-renderers.mjs",
    "check": "node --check main.js && node --check preload.js && node --check scripts/noelle_maintenance_v17.cjs && node --check scripts/diagnostico_v17.cjs && node --check scripts/rebuild_manifests_noelle.cjs && node --check src/renderer/controls_window_app.js && node --check src/renderer/avatar_window_app.js",
    "lint": "node scripts/diagnostico_v17.cjs --ci",
    "format": "node scripts/diagnostico_v17.cjs --format-check",
    "test": "node scripts/diagnostico_v17.cjs --ci"
  },
  "dependencies": {
    "@pixiv/three-vrm": "3.5.2",
    "three": "0.184.0",
    "@pixiv/three-vrm-animation": "3.5.2"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "esbuild": "0.28.0"
  },
  "build": {
    "appId": "com.masoritech.noelle",
    "productName": "Noelle Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "tools/**/*",
      "scripts/**/*",
      "requirements.txt"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/app.ico"
    }
  }
}
