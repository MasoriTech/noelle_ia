@echo off
setlocal EnableExtensions DisableDelayedExpansion
set "NOELLE_ORG_SELF=%~f0"
set "NOELLE_ORG_START=%CD%"
where powershell.exe >nul 2>nul
if errorlevel 1 (
  echo [ERRO] powershell.exe nao encontrado.
  pause
  exit /b 1
)
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "EC=%ERRORLEVEL%"
if not "%EC%"=="0" (
  echo.
  echo [ERRO] O organizador terminou com codigo %EC%.
  pause
)
exit /b %EC%

