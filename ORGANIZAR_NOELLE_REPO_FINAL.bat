@echo off
setlocal EnableExtensions
title Organizar Noelle Repo - Final
REM One-file BAT. It extracts an embedded Base64 PowerShell script to TEMP and runs it.
set "SELF=%~f0"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$f=$env:SELF;$m='###PS1_BASE64###';$raw=[IO.File]::ReadAllText($f);$i=$raw.LastIndexOf($m);if($i -lt 0){Write-Host '[ERRO] Payload nao encontrado.' -ForegroundColor Red;exit 10};$b64=$raw.Substring($i+$m.Length) -replace '[^A-Za-z0-9+/=]','';$bytes=[Convert]::FromBase64String($b64);$tmp=Join-Path $env:TEMP ('organizar_noelle_'+[guid]::NewGuid().ToString()+'.ps1');[IO.File]::WriteAllBytes($tmp,$bytes);& powershell -NoProfile -ExecutionPolicy Bypass -File $tmp;exit $LASTEXITCODE"
set "ERR=%ERRORLEVEL%"
if not "%ERR%"=="0" (
  echo.
  echo [ERRO] Organizacao terminou com codigo %ERR%.
  pause
)
exit /b %ERR%
###PS1_BASE64###


